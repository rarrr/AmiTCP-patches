+#!/usr/bin/env bash
+# build_vbcc.sh - Build AmiTCP-3.0b2 amitcp/ using VBCC m68k cross-compiler
+# Run from WSL inside the src/ directory: bash build_vbcc.sh
+
+set -e
+
+VBCC_BIN="/mnt/s/Amiga/vbcc/bin"
+VC="$VBCC_BIN/vc.exe"
+VBCC_CONFIG="S:/Amiga/vbcc/config/aos68k_wsl"
+
+# Derive paths from this script's location so the build works from any directory
+SRC_DIR="$(cd "$(dirname "$0")" && pwd)"
+BASE_DIR="$(dirname "$SRC_DIR")"
+
+# Convert a Linux /mnt/x/... path to a Windows X:/... path for vc.exe
+to_win() { echo "$1" | sed 's|^/mnt/\([a-zA-Z]\)/|\U\1:/|'; }
+
+BUILD_DIR="$BASE_DIR/build_vbcc"
+W_SRC="$(to_win "$SRC_DIR")"
+W_BUILD="$(to_win "$BUILD_DIR")"
+
+CFLAGS=(
+  "+$VBCC_CONFIG"
+  "-O1"
+  "-size"
+  "-DAMITCP"
+  "-DKERNEL"
+  "-DDIRECTED_BROADCAST"
+  "-DRCS_ID_C="
+  "-Dstrcasecmp=stricmp"
+  "-I$W_SRC/netinclude"
+  "-I$W_SRC/amitcp"
+  "-I$W_SRC/amitcp/conf"
+  "-I$W_SRC/amitcp/protos"
+)
+
+mkdir -p "$BUILD_DIR"
+mkdir -p "$BUILD_DIR/kern"
+mkdir -p "$BUILD_DIR/net"
+mkdir -p "$BUILD_DIR/netinet"
+mkdir -p "$BUILD_DIR/api"
+
+ERRORS=0
+COMPILED=0
+
+compile_file() {
+  local srcrel="$1"           # e.g. amitcp/kern/amiga_main.c
+  local objrel="${srcrel%.c}.o"  # e.g. amitcp/kern/amiga_main.o
+  local subdir
+  subdir="$(dirname "$srcrel" | sed 's|amitcp/||')"  # kern, net, netinet, api
+
+  local w_src="$W_SRC/$srcrel"
+  local w_obj="$W_BUILD/${subdir}/$(basename "${srcrel%.c}.o")"
+  local l_obj="$BUILD_DIR/${subdir}/$(basename "${srcrel%.c}.o")"
+
+  printf "  %-42s ... " "$srcrel"
+  if "$VC" "${CFLAGS[@]}" -c "$w_src" -o "$w_obj" 2>"$l_obj.log"; then
+    echo "OK"
+    ((COMPILED++)) || true
+  else
+    echo "FAIL  (see ${l_obj}.log)"
+    ((ERRORS++)) || true
+  fi
+}
+
+echo "=== Building kern/ ==="
+for f in \
+  amitcp/kern/amiga_main.c   amitcp/kern/amiga_time.c   amitcp/kern/amiga_config.c \
+  amitcp/kern/amiga_netdb.c  \
+  amitcp/kern/kern_synch.c   amitcp/kern/kern_malloc.c  amitcp/kern/uipc_mbuf.c \
+  amitcp/kern/uipc_domain.c  amitcp/kern/uipc_socket.c  amitcp/kern/uipc_socket2.c \
+  amitcp/kern/amiga_log.c    amitcp/kern/amiga_cstat.c  amitcp/kern/amiga_rexx.c \
+  amitcp/kern/subr_prf.c     amitcp/kern/accesscontrol.c amitcp/kern/config_var.c
+do
+  compile_file "$f"
+done
+
+echo ""
+echo "=== Building net/ ==="
+for f in \
+  amitcp/net/if.c           amitcp/net/if_loop.c \
+  amitcp/net/raw_cb.c       amitcp/net/raw_usrreq.c \
+  amitcp/net/route.c        amitcp/net/rtsock.c        amitcp/net/radix.c \
+  amitcp/net/if_sana.c      amitcp/net/netisr.c        amitcp/net/sana2config.c \
+  amitcp/net/sana2copybuff.c amitcp/net/sana2arp.c     amitcp/net/sana2perror.c
+do
+  compile_file "$f"
+done
+
+echo ""
+echo "=== Building netinet/ ==="
+for f in \
+  amitcp/netinet/in.c          amitcp/netinet/in_pcb.c     amitcp/netinet/in_proto.c \
+  amitcp/netinet/ip_icmp.c     amitcp/netinet/ip_input.c   amitcp/netinet/ip_output.c \
+  amitcp/netinet/raw_ip.c      amitcp/netinet/tcp_debug.c  amitcp/netinet/tcp_input.c \
+  amitcp/netinet/tcp_output.c  amitcp/netinet/tcp_subr.c   amitcp/netinet/tcp_timer.c \
+  amitcp/netinet/tcp_usrreq.c  amitcp/netinet/udp_usrreq.c
+do
+  compile_file "$f"
+done
+# Note: in_cksum.c excluded - uses asm (in_cksum.asm handles it)
+
+echo ""
+echo "=== Assembling netinet/in_cksum.asm ==="
+printf "  %-42s ... " "amitcp/netinet/in_cksum.asm"
+if /mnt/s/Amiga/vbcc/bin/vasmm68k_mot.exe -m68000 -I"$W_SRC/netinclude" -I"$W_SRC/amitcp" -I"S:/Amiga/vbcc/NDK_3.9/Include/include_i" -Fhunk -o "$W_BUILD/netinet/in_cksum.o" "$W_SRC/amitcp/netinet/in_cksum.asm" > "$BUILD_DIR/netinet/in_cksum.log" 2>&1; then
+  echo "OK"
+  ((COMPILED++)) || true
+else
+  echo "FAIL  (see $BUILD_DIR/netinet/in_cksum.log)"
+  ((ERRORS++)) || true
+fi
+
+echo ""
+echo "=== Building api/ ==="
+for f in \
+  amitcp/api/amiga_api.c       amitcp/api/amiga_libtables.c  amitcp/api/amiga_syscalls.c \
+  amitcp/api/amiga_sendrecv.c  amitcp/api/amiga_generic.c    amitcp/api/amiga_generic2.c \
+  amitcp/api/amiga_libcalls.c  amitcp/api/amiga_errlists.c   \
+  amitcp/api/getxbyy.c         amitcp/api/gethostnamadr.c    amitcp/api/allocdatabuffer.c \
+  amitcp/api/res_comp.c        amitcp/api/res_debug.c        amitcp/api/res_init.c \
+  amitcp/api/res_mkquery.c     amitcp/api/res_query.c        amitcp/api/res_send.c  \
+  amitcp/api/auto_extras.c     amitcp/api/auto_inetaddr.c    amitcp/api/auto_netdb.c \
+  amitcp/api/auto_nonsocket.c  amitcp/api/auto_protocols.c   amitcp/api/auto_socket.c
+do
+  compile_file "$f"
+done
+
+echo ""
+echo "=== Summary ==="
+echo "  Compiled OK : $COMPILED"
+echo "  Errors      : $ERRORS"
+echo ""
+
+if [ "$ERRORS" -eq 0 ]; then
+  echo "=== Linking AmiTCP ==="
+  # Find all .o files and convert them to Windows paths for vc.exe
+  O_FILES=$(find "$BUILD_DIR" -name "*.o" | while read -r f; do to_win "$f"; done | tr '\n' ' ')
+  W_AMIGALIB="$(to_win "$VBCC_BIN/../targets/m68k-amigaos/lib/amiga.lib")"
+
+  if "$VC" "+$VBCC_CONFIG" -o "$W_BUILD/AmiTCP" $O_FILES "$W_AMIGALIB" > "$BUILD_DIR/link.log" 2>&1; then
+    echo "Linking SUCCESS: $W_BUILD/AmiTCP"
+  else
+    echo "Linking FAIL  (see $BUILD_DIR/link.log)"
+    ((ERRORS++)) || true
+  fi
+fi
+
+if [ "$ERRORS" -eq 0 ]; then
+  echo "All files compiled and linked successfully!"
+else
+  echo "Build failed. Check *.log files under $BUILD_DIR/"
+  echo "Quick error summary:"
+  find "$BUILD_DIR" -name "*.log" -size +0 | while read -r logfile; do
+    echo ""
+    echo "--- $logfile ---"
+    grep -i "error" "$logfile" | head -5
+  done
+fi
