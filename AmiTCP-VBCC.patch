+/*
+ * apicalls_vbcc.h - AmiTCP/IP internal API call stubs for VBCC
+ *
+ * Equivalent of apicalls_sasc.h, using VBCC __reg() register convention
+ * instead of SAS/C "register __reg" syntax.
+ */
+
+#ifndef API_APICALLS_VBCC_H
+#define API_APICALLS_VBCC_H
+
+#ifndef API_APICALLS_H
+#error include <api/apicalls.h> instead of <api/apicalls_vbcc.h>
+#endif
+
+#ifndef EXEC_TYPES_H
+#include <exec/types.h>
+#endif
+
+#ifndef SYS_TYPES_H
+#include <sys/types.h>
+#endif
+
+#ifndef SYS_TIME_H
+#include <sys/time.h>
+#endif
+
+#include <stdarg.h>
+
+extern LONG _CloseSocket(__reg("a6") struct SocketBase *,
+                         __reg("d0") LONG);
+
+extern LONG _connect(__reg("a6") struct SocketBase *,
+                     __reg("d0") LONG,
+                     __reg("a0") struct sockaddr *,
+                     __reg("d1") LONG);
+
+extern LONG _recv(__reg("a6") struct SocketBase *,
+                  __reg("d0") LONG,
+                  __reg("a0") char *,
+                  __reg("d1") LONG,
+                  __reg("d2") LONG);
+
+extern LONG _send(__reg("a6") struct SocketBase *,
+                  __reg("d0") LONG,
+                  __reg("a0") char *,
+                  __reg("d1") LONG,
+                  __reg("d2") LONG);
+
+extern LONG _sendto(__reg("a6") struct SocketBase *,
+                    __reg("d0") LONG,
+                    __reg("a0") char *,
+                    __reg("d1") LONG,
+                    __reg("d2") LONG,
+                    __reg("a1") struct sockaddr *,
+                    __reg("d3") LONG);
+
+extern LONG _socket(__reg("a6") struct SocketBase *,
+                    __reg("d0") LONG,
+                    __reg("d1") LONG,
+                    __reg("d2") LONG);
+
+extern LONG _WaitSelect(__reg("a6") struct SocketBase *,
+                        __reg("d0") ULONG,
+                        __reg("a0") fd_set *,
+                        __reg("a1") fd_set *,
+                        __reg("a2") fd_set *,
+                        __reg("a3") struct timeval *,
+                        __reg("d1") ULONG *);
+
+extern struct hostent * _gethostbyaddr(__reg("a6") struct SocketBase *,
+                                       __reg("a0") const UBYTE *,
+                                       __reg("d0") int,
+                                       __reg("d1") int);
+
+extern LONG _gethostname(__reg("a6") struct SocketBase *,
+                         __reg("a0") STRPTR,
+                         __reg("d0") LONG);
+
+extern LONG _SetErrnoPtr(__reg("a6") struct SocketBase *,
+                         __reg("a0") VOID *,
+                         __reg("d0") UBYTE);
+
+#define BASE_EXT_DECL
+#define BASE_PAR_DECL  struct SocketBase * SocketBase,
+#define BASE_PAR_DECL0 struct SocketBase * SocketBase
+#define BASE_NAME SocketBase
+
+static LONG
+CloseSocket (BASE_PAR_DECL LONG d)
+{
+  return _CloseSocket(SocketBase, d);
+}
+
+static LONG
+connect (BASE_PAR_DECL LONG s, struct sockaddr * name, LONG namelen)
+{
+  return _connect(SocketBase, s, name, namelen);
+}
+
+static LONG
+recv (BASE_PAR_DECL LONG s, char * buf, LONG len, LONG flags)
+{
+  return _recv(SocketBase, s, buf, len, flags);
+}
+
+static LONG
+send (BASE_PAR_DECL LONG s, char * msg, LONG len, LONG flags)
+{
+  return _send(SocketBase, s, msg, len, flags);
+}
+
+static LONG
+sendto (BASE_PAR_DECL LONG s, char * msg, LONG len, LONG flags,
+        struct sockaddr * to, LONG tolen)
+{
+  return _sendto(SocketBase, s, msg, len, flags, to, tolen);
+}
+
+static LONG
+socket (BASE_PAR_DECL LONG domain, LONG type, LONG protocol)
+{
+  return _socket(SocketBase, domain, type, protocol);
+}
+
+static LONG
+WaitSelect (BASE_PAR_DECL LONG nfds, fd_set * readfds, fd_set * writefds,
+            fd_set * exceptfds, struct timeval * timeout, ULONG * maskp)
+{
+  return _WaitSelect(SocketBase, nfds, readfds, writefds, exceptfds, timeout, maskp);
+}
+
+static struct hostent *
+gethostbyaddr (BASE_PAR_DECL const UBYTE * addr, int len, int type)
+{
+  return _gethostbyaddr(SocketBase, addr, len, type);
+}
+
+static LONG
+gethostname (BASE_PAR_DECL STRPTR name, LONG namelen)
+{
+  return _gethostname(SocketBase, name, namelen);
+}
+
+static LONG
+SetErrnoPtr (BASE_PAR_DECL VOID * err_p, UBYTE size)
+{
+  return _SetErrnoPtr(SocketBase, err_p, size);
+}
+
+#undef BASE_EXT_DECL
+#undef BASE_PAR_DECL
+#undef BASE_PAR_DECL0
+#undef BASE_NAME
+
+#endif /* API_APICALLS_VBCC_H */
